generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  username     String       @unique
  role         Role         @default(REVIEWER)
  passwordHash String?
  restaurants  Restaurant[]
  reviews      Review[]     @relation("UserReviews")
  favorites    Favorite[]   @relation("UserFavorites")
  comments  Comment[]
  ownerReplies OwnerReply[]
}

model Favorite {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  createdAt    DateTime @default(now())

  user       User       @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
}

model Restaurant {
  id                  String           @id @default(uuid())
  name                String
  description         String
  cuisineType         String
  address             String
  priceRange          String           @default("$$")
  area                String           @default("Athens")
  views               Int              @default(0)
  globalBayesianScore Float            @default(0.0)
  ownerId             String
  status              RestaurantStatus @default(PENDING)
  createdAt           DateTime         @default(now())
  imageUrl            String?
  owner               User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviews             Review[]
  favorites           Favorite[]

  openTime    String   @default("10:00")
  closeTime   String   @default("23:30")
}
model OwnerReply {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())
  
  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model Review {
  id               String   @id @default(uuid())
  rating           Int
  createdAt        DateTime @default(now())
  restaurantId     String
  userId           String
  atmosphereRating Int
  foodRating       Int
  upvotes          Int      @default(0)
  serviceRating    Int
  simpleAverage    Float
  images           String[]
  text             String
  vfmRating        Int
  comments  Comment[]

  ownerReply OwnerReply?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)
}
model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
enum RestaurantStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum Role {
  VISITOR
  REVIEWER
  OWNER
  ADMIN
}
