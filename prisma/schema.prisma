generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  username     String       @unique
  role         Role         @default(REVIEWER)
  passwordHash String?
  restaurants  Restaurant[]
  reviews      Review[]
}

model Restaurant {
  id                  String           @id @default(uuid())
  name                String
  description         String
  cuisineType         String
  address             String
  globalBayesianScore Float            @default(0.0)
  ownerId             String
  status              RestaurantStatus @default(PENDING)
  createdAt           DateTime         @default(now())
  imageUrl            String?
  owner               User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviews             Review[]
}

model Review {
  id               String     @id @default(uuid())
  rating           Int
  createdAt        DateTime   @default(now())
  restaurantId     String
  userId           String
  atmosphereRating Int
  foodRating       Int
  serviceRating    Int
  simpleAverage    Float
  text             String
  vfmRating        Int
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RestaurantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  VISITOR
  REVIEWER
  OWNER
  ADMIN
}
